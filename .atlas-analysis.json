  "keyFeatures": [
    "Augmented reality (AR) visualization of 3D molecular structures using WebXR",
    "Interactive 3D lab instrument models (gradilla, matraz, autoclave, placa calefactora, etc.)",
    "Full interactive periodic table with element properties (mass, ionization energy, electronegativity, oxidation states)",
    "Three virtual laboratories: General Chemistry, Instrumental Analysis, and Chemical Plants",
    "User registration and login with hashed password authentication and session management",
    "Dark/light mode toggle with localStorage persistence",
    "Mobile-responsive design with Tailwind CSS",
    "Docker-based deployment with PHP 8.2 + Apache"
  ],
  "publicApiSurface": [
    "GET /index.php — Public landing page",
    "GET /registro.php — User registration form",
    "POST /php/validar.php — Registration validation and account creation",
    "GET /iniciosesion.php — Login form",
    "POST /php/log.php — Login authentication (MySQL: registro_RALQ.usuarios)",
    "GET /php/logout.php — Session logout",
    "GET /menu.php — Authenticated main menu (requires session)",
    "GET /estructuras-mol.php — 3D molecular structures viewer",
    "GET /laboratorios.php — Virtual labs hub",
    "GET /quimica-general.php — General chemistry lab instruments",
